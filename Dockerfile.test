# BindMaster test environment — GPU-capable CUDA 12.4 base image (x86_64, Ubuntu 22.04)
#
# Build (base):  docker build -f Dockerfile.test -t bindmaster-test .
# Build (test):  docker build -f Dockerfile.test --target test -t bindmaster-test-run .
# Run:           ./test_env.sh

# ── Base stage: CUDA 12.4 + Miniforge + system packages ──────────────────────
FROM nvidia/cuda:12.4.1-devel-ubuntu22.04 AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV CONDA_BASE=/opt/miniforge3
ENV PATH=/opt/miniforge3/bin:${PATH}

# ── System packages ──────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    wget \
    curl \
    ca-certificates \
    sudo \
    libgomp1 \
    libgfortran5 \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# ── Miniforge3 (mamba + conda) ──────────────────────────────────────────────
RUN wget -q \
    "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh" \
    -O /tmp/miniforge.sh \
    && bash /tmp/miniforge.sh -b -p /opt/miniforge3 \
    && rm /tmp/miniforge.sh \
    && /opt/miniforge3/bin/conda clean -a -y \
    && chmod -R 755 /opt/miniforge3

# Allow any UID to create conda envs and cache packages
RUN mkdir -p /opt/conda-envs /opt/conda-pkgs \
    && chmod 777 /opt/conda-envs /opt/conda-pkgs \
    && /opt/miniforge3/bin/conda config --system --add envs_dirs /opt/conda-envs \
    && /opt/miniforge3/bin/conda config --system --add pkgs_dirs /opt/conda-pkgs

# ── Entrypoint ───────────────────────────────────────────────────────────────
COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["/bin/bash", "--login"]

# ── Test stage: runs the installer non-interactively ─────────────────────────
FROM base AS test

COPY . /workspace
RUN bash install/install.sh --tool all --yes --skip-examples

# ── Standalone test: no pre-installed conda, installs Miniforge locally ──────
#
# Simulates a server where system conda exists but is NOT writable (like the
# colleague's /software/ncbr/... setup). Tests that standalone auto-detection,
# .condarc pinning, binutils install, and BindCraft all work correctly.
#
# Build:  docker build -f Dockerfile.test --target standalone-test -t bindmaster-standalone .
# Verify: docker run --rm bindmaster-standalone bash -c "conda/bin/conda env list && cat conda/.condarc"
FROM nvidia/cuda:12.4.1-devel-ubuntu22.04 AS standalone-test

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl wget ca-certificates python3 build-essential \
    && rm -rf /var/lib/apt/lists/*

# Simulate an unwritable system conda (like /software/ncbr/softrepo/...):
# install Miniforge but make envs dir read-only, so standalone mode triggers
RUN wget -q "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh" \
        -O /tmp/miniforge.sh \
    && bash /tmp/miniforge.sh -b -p /opt/system-conda \
    && rm /tmp/miniforge.sh \
    && chmod -R 555 /opt/system-conda/envs
ENV PATH="/opt/system-conda/bin:${PATH}"

COPY . /workspace
WORKDIR /workspace

# Stage 1: Install Mosaic (fast, tests standalone Miniforge + .condarc + uv)
RUN bash install/install.sh --tool mosaic --yes --skip-examples \
    && test -d conda/bin \
    && test -f bin/mosaic \
    && cat conda/.condarc \
    && grep -q "conda-forge" conda/.condarc \
    && grep -q "envs_dirs" conda/.condarc \
    && Mosaic/.venv/bin/python -c "import mosaic; print('Mosaic OK')"

# Stage 2: Install BindCraft (tests binutils, ocl-icd, colabdesign — the failures)
RUN bash install/install.sh --tool bindcraft --yes --skip-examples \
    && test -d conda/envs/BindCraft \
    && conda/bin/conda run -n BindCraft python -c "from colabdesign import mk_af_model; print('BindCraft OK')"
